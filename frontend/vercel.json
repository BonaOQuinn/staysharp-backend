{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    {
      "source": "/",
      "destination": "/html/index.html"
    },
    {
      "source": "/booking.html",
      "destination": "/html/booking.html"
    },
    {
      "source": "/services.html",
      "destination": "/html/services.html"
    },
    {
      "source": "/(.*)",
      "destination": "/$1"
    }
  ]
}